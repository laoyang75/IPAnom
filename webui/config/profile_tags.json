{
  "version": 9,
  "description": "H库 Block 漏斗式画像标签 v9。顺序：移动3运营商 → 混合网络 → 云IDC → 轻度混合 → 异常检测 → 固定网络(拆运营商)。标签按顺序执行，每个标签在前面标签的剩余池上工作。",
  "tags": [
    {
      "id": "mobile_cmcc",
      "name": "正常移动出口·中国移动",
      "emoji": "📱",
      "color": "#3fb950",
      "logic": "AND",
      "description": "中国移动移动NAT出口。移动IP少(仅8块)但设备密度高(P50=40/IP)、应用多样性强(P50=19/IP)、DAA/DNA正常(P50=17.6)。",
      "conditions": [
        {"field": "top_operator", "op": "=", "value": "中国移动", "label": "运营商=中国移动"},
        {"field": "mobile_device_ratio", "op": ">=", "value": 0.85, "label": "移动占比 ≥ 85%"},
        {"field": "daa_dna_ratio", "op": ">=", "value": 8, "label": "DAA/DNA ≥ 8"},
